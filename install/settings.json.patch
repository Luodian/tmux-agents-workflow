{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{PLUGIN_DIR}}/scripts/hook-session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{PLUGIN_DIR}}/scripts/hook_prompt_submit.py",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "python3 {{PLUGIN_DIR}}/scripts/hook_post_todo_write.py",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{PLUGIN_DIR}}/scripts/hook-stop-diff.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
