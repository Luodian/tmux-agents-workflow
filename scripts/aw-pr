#!/usr/bin/env bash
# aw-pr — soft merge gate around `gh pr create`.
#
# Refuses to create the PR if `.agentwf/spec.md` > To-dos has any
# unchecked items. Use `aw-pr --force` to bypass after acknowledging.
# All other arguments are forwarded to `gh pr create` unchanged.

set -euo pipefail
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SYNC="$HERE/todos_sync.py"
# shellcheck source=_aw_lib.sh
. "$HERE/_aw_lib.sh"

force=0
gh_args=()
for arg in "$@"; do
  case "$arg" in
    --force|-f) force=1 ;;
    *) gh_args+=("$arg") ;;
  esac
done

root="$(aw_repo_root)"
spec=""
[[ -n "$root" ]] && spec="$(aw_resolve_spec "$root")"

if [[ -n "$spec" && -f "$spec" && "$force" -eq 0 ]]; then
  unchecked="$(python3 "$SYNC" count --file "$spec" --unchecked-only)"
  if [[ "$unchecked" -gt 0 ]]; then
    printf '\033[31m✘\033[0m %s unchecked todo(s) in %s:\n' "$unchecked" "$spec" >&2
    python3 "$SYNC" extract To-dos --file "$spec" \
      | grep -E '^\s*-\s*\[[ ~]\]' | sed 's/^/  /' >&2
    printf '\nRun \033[1maw-pr --force\033[0m to bypass.\n' >&2
    exit 1
  fi
fi

exec gh pr create "${gh_args[@]}"
